{
	"schemaVersion": 1,
	"id": "jade-create-addon",
	"version": "${version}",
	"name": "Jade Create Addon",
	"description": "Addon for Jade that made to make it useful and informational compatible with Create mod",
	"authors": [
		"Hydraa"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/hydraa94/JadeCreateAddons"
	},
	"license": "CC-BY-NC-SA-4.0",
	"icon": "assets/jade-create-addon/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.hydraa.jadecreateaddon.JadeCreateAddon"
		],
        "jade": [
          "com.hydraa.jadecreateaddon.create.CreatePlugin"
        ],
        "modmenu": [
          "com.hydraa.jadecreateaddon.ModMenuCompat"
        ]
	},
	"mixins": [
		"jade-create-addon.mixins.json"
	],
    "depends": {
      "fabricloader": ">=0.19.2",
      "minecraft": "~26.1.2",
      "java": ">=25",
      "fabric-api": "*",
      "jade": "*",
      "create": "*"
    },
    "breaks": {
      "create": "<6"
    },
    "suggests": {
      "modmenu": "*"
    }
}